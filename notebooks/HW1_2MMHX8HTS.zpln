    {
      "text": "%spark.pyspark\nfrom pyspark.sql.window import Window\n\nw \u003d Window.partitionBy(\"city\").orderBy(F.desc(\"revenue_sum\"))\n\ntop2 \u003d (\n    agg\n    .withColumn(\"rn\", F.row_number().over(w))\n    .filter(F.col(\"rn\") \u003c\u003d 2)\n    .orderBy(\"city\", \"rn\")\n)\n\ntop2.show()",
