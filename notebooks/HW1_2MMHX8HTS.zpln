      "text": "%spark.pyspark\njoined \u003d (\n    orders_enriched\n    .join(users, on\u003d\"user_id\", how\u003d\"inner\")\n    .join(products, on\u003d\"product_id\", how\u003d\"inner\")\n)\n\njoined.show()",
